# LLM Provider: openai | anthropic | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Default model per provider (optional; LiteLLM fallbacks apply)
LLM_MODEL=gpt-4o

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/analyst.db

# Storage
UPLOAD_DIR=./data/uploads

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
